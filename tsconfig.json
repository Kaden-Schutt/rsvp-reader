{
  "compilerOptions": {
    "baseUrl": "src",
    "target": "ES2018",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": ["ES2018", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "declaration": false,
    "outDir": "dist",
    "sourceMap": true,
    "importHelpers": true,
    "noEmit": true
  },
  "include": ["src/**/*.ts"]
}
